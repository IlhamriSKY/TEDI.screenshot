{
  "id": "tedi.screenshot",
  "name": "Screenshot",
  "version": "0.5.2",
  "description": "Captures the entire TEDI window to PNG, saves it to Downloads, and copies it to the clipboard. Click the status bar camera icon or press Ctrl+Alt+S.",
  "author": "IlhamRiski - ilhamriski.com",
  "homepage": "https://github.com/IlhamriSKY/TEDI.screenshot",
  "icon": "logo.png",
  "main": "extension.js",
  "permissions": [
    "panels:register",
    "ui:toast",
    "invoke:shell_bg_spawn_direct",
    "invoke:shell_bg_logs",
    "invoke:shell_bg_kill"
  ],
  "contributes": {
    "commands": [
      {
        "id": "tedi.screenshot.capture",
        "title": "Capture TEDI window",
        "category": "Screenshot"
      }
    ],
    "keybindings": [
      {
        "command": "tedi.screenshot.capture",
        "key": "Mod+Alt+S"
      }
    ],
    "panels": [
      {
        "id": "screenshot",
        "title": "Screenshot",
        "surface": "right",
        "icon": "logo.png",
        "defaultOpen": false,
        "toggleCommand": "tedi.screenshot.capture",
        "hideHostHeader": true,
        "compact": true
      }
    ]
  },
  "engines": { "tedi": ">=0.2.20" }
}
