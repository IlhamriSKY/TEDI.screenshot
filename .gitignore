# Local build output produced by the CI workflow; never committed.
dist/

# Rust sidecar build artifacts (compiled per platform by CI).
sidecar-src/target/

# Locally-collected sidecar binaries (CI uploads these as release assets;
# we don't commit them).
sidecar/

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# JS build tooling + built bundle (CI builds extension.js into the release .zip).
node_modules/
/extension.js
